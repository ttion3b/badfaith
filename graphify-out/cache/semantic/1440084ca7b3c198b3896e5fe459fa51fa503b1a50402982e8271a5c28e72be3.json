{"nodes": [{"id": "docs_gdd_03_pactes_pacte", "label": "Pacte", "file_type": "concept", "source_file": "docs/gdd/03-pactes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Offre secrete de La Direction: gain en Poche Perso + consequence publique differee de 20-90 s (le temps de se fabriquer un alibi). Anonyme en partie, revele au Tribunal. Distribution: 1 par joueur toutes les 2-3 min, jamais le meme a deux joueurs, pitie anti-ciblage."}, {"id": "docs_gdd_03_pactes_la_montre", "label": "La Montre", "file_type": "concept", "source_file": "docs/gdd/03-pactes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Seule UI du jeu (diegetique, pas de HUD). Vibration audible a ~2 m, consultation = animation publique: regarder sa montre devient un TELL social \u2014 la montre elle-meme genere de la mauvaise foi (fake-checks, accusations)."}, {"id": "docs_gdd_03_pactes_blackout", "label": "Pacte Blackout", "file_type": "concept", "source_file": "docs/gdd/03-pactes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_gdd_03_pactes_porte_grippee", "label": "Pacte Porte grippee", "file_type": "concept", "source_file": "docs/gdd/03-pactes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_gdd_03_pactes_brouillage", "label": "Pacte Brouillage", "file_type": "concept", "source_file": "docs/gdd/03-pactes.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Coupe le micro d'un joueur cible 45 s: il ne peut plus appeler a l'aide ni se defendre."}, {"id": "docs_gdd_03_pactes_prime_sur_tete", "label": "Pacte Prime sur tete", "file_type": "concept", "source_file": "docs/gdd/03-pactes.md", "source_location": null, "source_url": null, "captured_