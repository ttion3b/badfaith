{"nodes": [{"id": "docs_gdd_05_le_juge_le_juge", "label": "Le Juge (revolver unique)", "file_type": "concept", "source_file": "docs/gdd/05-le-juge.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Un seul revolver, une seule balle. But premier: instrument de braquage au micro et de bluff, pas de kill. Verifier le barillet est PRIVE (le bluff survit au tir); le tir est entendu de toute la map mais pas localise. Tirer est l'acte le moins deniable du jeu \u2014 voulu: le cout du meurtre direct est social, pas mecanique."}, {"id": "docs_gdd_05_le_juge_braquage", "label": "Braquage au micro", "file_type": "concept", "source_file": "docs/gdd/05-le-juge.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Aucun systeme mecanique \u2014 pur roleplay vocal. Le jeu fournit l'arme, les joueurs fournissent le theatre."}], "edges": [{"source": "docs_gdd_03_pactes_prime_sur_tete", "target": "docs_gdd_05_le_juge_le_juge", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/gdd/05-le-juge.md", "source_location": null, "weight": 1.0}, {"source": "docs_gdd_05_le_juge_le_juge", "target": "docs_gdd_05_le_juge_braquage", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/gdd/05-le-juge.md", "source_location": null, "weight": 1.0}, {"source": "docs_gdd_05_le_juge_le_juge", "target": "docs_gdd_08_viralite_gopro", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/gdd/05-le-juge.md", "source_location": null, "weight": 1.0}, {"source": "docs_gdd_05_le_juge_le_juge", "target": "docs_gdd_02_economie_regle_de_la_mort", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/gdd/05-le-juge.md", "source_location": null, "weight": 1.0}],