{"nodes": [{"id": "docs_gdd_07_tribunal_tribunal", "label": "Le Tribunal", "file_type": "concept", "source_file": "docs/gdd/07-tribunal.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Sequence post-game scriptee ~3 min, presentee comme une emission par La Direction. Rejoue 4-6 incidents les plus dramatiques: accusation (20 s) -> defense (15 s) -> receipt video -> verdict. L'equivalent du meeting d'Among Us mais avec preuves video. Doit finir sur une faim, pas un soulagement."}, {"id": "docs_gdd_07_tribunal_receipt", "label": "Le Receipt (preuve GoPro)", "file_type": "concept", "source_file": "docs/gdd/07-tribunal.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Extrait GoPro diegetique diffuse au Tribunal: poignet qui se leve -> montre affichant l'offre -> le pouce appuie -> coupe sur la consequence. Ce plan de 8 secondes EST le format TikTok du jeu."}, {"id": "docs_gdd_07_tribunal_prime_de_mauvaise_foi", "label": "Prime de mauvaise foi (scoring du mensonge)", "file_type": "concept", "source_file": "docs/gdd/07-tribunal.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Coupable non designe majoritairement: +50 % du gain du Pacte. Demasque: rembourse le gain aux votants justes. Fausse accusation: amende 500 $ (accuser a un cout). Flair: +300 $ par verdict correct, les morts votent aussi \u2014 perdre reste un jeu."}], "edges": [{"source": "docs_gdd_00_vision_among_us", "target": "docs_gdd_07_tribunal_tribunal", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/gdd/07-tribunal.md", "source_location": null, "weight": 1.0}, {"source": "docs_gdd_07_tribunal_tribunal", "target": "docs_gdd_07_tribunal_receipt", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_f